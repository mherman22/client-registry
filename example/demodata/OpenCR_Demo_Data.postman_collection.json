{
  "info": {
    "name": "OpenCR Demo Data",
    "description": "Load demo patients into OpenCR to demonstrate matching scenarios.\n\nScenarios:\n1. Auto-match via National ID (deterministic Rule 1)\n2. Auto-match via demographics (probabilistic Rule 2 \u2014 all 4 fields)\n3. Potential match \u2014 similar demographics, needs human review\n4. No match \u2014 unique person, gets own golden record\n5. Roaming care \u2014 same patient at different facilities\n6. Multiple identifiers display\n7. Multiple birth indicator\n\nRun Authenticate first, then run the patient folder.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:3002",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authenticate",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ocrux/user/authenticate?username=root@intrahealth.org&password=intrahealth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "ocrux",
            "user",
            "authenticate"
          ],
          "query": [
            {
              "key": "username",
              "value": "root@intrahealth.org"
            },
            {
              "key": "password",
              "value": "intrahealth"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set(\"token\", jsonData.token);",
              "    pm.test(\"Token received\", function () {",
              "        pm.expect(jsonData.token).to.be.a(\"string\");",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
