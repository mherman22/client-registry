{
  "info": {
    "name": "OpenCR Demo Data",
    "description": "Load 10 demo patients into OpenCR for development and testing.\n\nIncludes:\n- 10 patients from Haiti\n- 2 patients share National ID NAT-88001 (Jean Baptiste) -> should auto-match\n- 2 patients share National ID NAT-88002 (Marie Dupont) -> should auto-match\n- 2 patients have multi-birth indicators\n- Patients from OpenMRS and OpenELIS sources\n\n**Setup:** Run the \"Authenticate\" request first to get a token, then run the patient requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:3002",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authenticate",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/ocrux/user/authenticate?username=root@intrahealth.org&password=intrahealth",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "ocrux",
            "user",
            "authenticate"
          ],
          "query": [
            {
              "key": "username",
              "value": "root@intrahealth.org"
            },
            {
              "key": "password",
              "value": "intrahealth"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set(\"token\", jsonData.token);",
              "    pm.test(\"Token received\", function () {",
              "        pm.expect(jsonData.token).to.be.a(\"string\");",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
