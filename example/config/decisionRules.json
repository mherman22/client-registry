{
  "__comments": {
    "threshold": {
      "jaro-winkler": "0 = no match, 1 = exact match",
      "exact": "binary — scores 1 if identical, 0 otherwise"
    },
    "scoring": {
      "deterministic": "each matching field adds its weight (default 1) to the score",
      "probabilistic": "Fellegi-Sunter model — score is a weighted sum of field similarities"
    },
    "thresholds": {
      "potentialMatchThreshold": "minimum score for ES to return the document (min_score)",
      "autoMatchThreshold": "score >= this → auto-match (linked automatically)",
      "between": "potentialMatchThreshold <= score < autoMatchThreshold → potential match (needs human review)"
    }
  },
  "rules": [
    {
      "__description": "Rule 1: National ID exact match — deterministic auto-match",
      "matchingType": "deterministic",
      "rule": "1",
      "fields": {
        "nationalId": {
          "algorithm": "exact",
          "fhirpath": "identifier.where(system='http://health.go.ug/cr/nationalid').value",
          "espath": "nationalId",
          "null_handling": "conservative",
          "null_handling_both": "conservative"
        }
      },
      "potentialMatchThreshold": 1,
      "autoMatchThreshold": 1
    },
    {
      "__description": "Rule 2: Name + Gender + DOB fuzzy match — probabilistic. All 4 fields = auto-match (score ~4), 3 fields = potential match (score ~3)",
      "matchingType": "probabilistic",
      "rule": "2",
      "fields": {
        "given": {
          "algorithm": "jaro-winkler",
          "threshold": 0.8,
          "fhirpath": "name.first().given",
          "espath": "given",
          "null_handling": "conservative",
          "null_handling_both": "conservative"
        },
        "family": {
          "algorithm": "jaro-winkler",
          "threshold": 0.8,
          "fhirpath": "name.first().family",
          "espath": "family",
          "null_handling": "conservative",
          "null_handling_both": "conservative"
        },
        "gender": {
          "algorithm": "exact",
          "fhirpath": "gender",
          "espath": "gender",
          "null_handling": "conservative",
          "null_handling_both": "conservative"
        },
        "birthDate": {
          "algorithm": "exact",
          "fhirpath": "birthDate",
          "espath": "birthDate",
          "null_handling": "conservative",
          "null_handling_both": "conservative"
        }
      },
      "potentialMatchThreshold": 3,
      "autoMatchThreshold": 4
    }
  ]
}
